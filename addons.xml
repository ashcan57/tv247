<addons>
    <addon id="repository.tv247"
           name="TV247 Repository"
           version="1.0.0"
           provider-name="TV247">
        <extension point="xbmc.addon.repository"
                   name="TV247 Repo">
            <info compressed="false">https://ashcan57.github.io/tv247/addons.xml</info>
            <checksum>https://ashcan57.github.io/tv247/addons.xml.md5</checksum>
            <datadir zip="true">https://ashcan57.github.io/tv247/zips/</datadir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary>TV247 Build & Installer Repo</summary>
            <description>Updates & Installer for TV247.</description>
            <platform>all</platform>
        </extension>
    </addon>

    <addon id="script.tv247.installer"
           name="TV247 Build Installer"
           version="1.0.0"
           provider-name="TV247">
        <extension point="xbmc.python.script"
                   library="default.py" />
        <extension point="xbmc.addon.metadata">
            <summary>TV247 Installer</summary>
            <description>Downloads and installs the Encore build.</description>
            <platform>all</platform>
        </extension>
    </addon>
</addons>

