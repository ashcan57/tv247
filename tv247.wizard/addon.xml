<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon
    id="tv247.wizard"
    name="TV247 Wizard"
    version="1.1.0"
    provider-name="ashcan57"
    type="xbmc.python.script"
    requires="xbmc.python,2.26.0"
    summary="First‑run wizard that configures TV247"
    description="Guides the user through the initial configuration of TV247 (download, API key, etc.)."
    icon="resources/icon.png"
    fanart="resources/fanart.jpg"
    website="https://github.com/ashcan57/tv247-wizard">

    <!-- Metadata – tells Kodi this is an executable script -->
    <extension point="xbmc.addon.metadata" library="default.py">
        <provides>
            <executable/>
        </provides>
    </extension>

    <!-- Settings – optional, but useful for persisting wizard choices -->
    <extension point="xbmc.addon.settings">
        <settings>
            <category label="Wizard Options">
                <setting id="first_run_done" type="boolean" default="false" label="Wizard completed"/>
                <setting id="api_key" type="text" default="" label="TV247 API key"/>
            </category>
        </settings>
    </extension>

</addon>