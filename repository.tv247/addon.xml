<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon
    id="repository.tv247"
    name="TV247 Repository"
    version="1.0.0"
    provider-name="ashcan57"
    type="xbmc.addon.repository"
    requires="xbmc.python,2.26.0"
    summary="Repository for TV247 wizard and video plug‑in"
    description="Official repository that hosts the TV247 setup wizard and the EV247 video plug‑in."
    icon="icon.png"
    website="https://github.com/ashcan57/tv247-repo"
    disallow="all">

    <!-- Repository definition – mandatory -->
    <extension point="xbmc.addon.repository" name="TV247 Repository">
        <info>
            <checksum>md5</checksum>
            <size>auto</size>
        </info>
    </extension>

    <!-- Optional metadata (nice for the repo list) -->
    <extension point="xbmc.addon.metadata">
        <summary>TV247 add‑ons</summary>
        <description>Contains the TV247 setup wizard and the EV247 video plug‑in.</description>
    </extension>

</addon>